{
  "name": "wnotes",
  "version": "1.0.0",
  "description": "A note-taking application built with Electron and Vue3",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p src/main",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && tsc -p src/main && electron-builder",
    "electron:preview": "vite build && tsc -p src/main && electron .",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "electron",
    "vue",
    "notes"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.0.0",
    "vue": "^3.4.0",
    "pinia": "^2.1.7",
    "md-editor-v3": "^4.12.0",
    "better-sqlite3": "^9.2.2",
    "sharp": "^0.33.1",
    "ant-design-vue": "^4.1.0",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron-builder": "^24.9.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/sharp": "^0.31.1",
    "@types/node": "^20.10.5",
    "@vue/tsconfig": "^0.5.1",
    "vue-tsc": "^1.8.25",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.wnotes.app",
    "productName": "WNotes",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
